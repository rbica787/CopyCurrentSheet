Sub CopyCurrentSheet()
    Dim sheetName As String
    Dim numCopies As Integer
    Dim i As Integer
    Dim originalSheet As Worksheet
    
    ' Prompt the user for the number of copies
    On Error GoTo InvalidInput
    numCopies = InputBox("How many copies would you like to make?", "Copy Sheet")
    If numCopies <= 0 Then GoTo InvalidInput
    
    ' Get the name of the current sheet
    Set originalSheet = ActiveSheet
    sheetName = originalSheet.Name
    
    ' Make the specified number of copies to the right of the original sheet
    For i = 1 To numCopies
        originalSheet.Copy After:=originalSheet
        Sheets(originalSheet.Index + i).Name = sheetName & " Copy " & i
    Next i
    
    Exit Sub

InvalidInput:
    MsgBox "Please enter a valid number of copies.", vbExclamation
End Sub
